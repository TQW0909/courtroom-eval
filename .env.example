# =============================================================================
# Courtroom Eval — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- OpenAI (required if using GPT models) ---
OPENAI_API_KEY=sk-...

# --- Ollama (optional — defaults shown) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- LangSmith tracing (optional) ---
# Set to "true" to enable LangSmith run tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=courtroom-eval
